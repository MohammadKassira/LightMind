  "normalization_method": {
    "scope": "per-lane/per-tls constants derived once from SUMO network metadata at startup",
    "manual_global_constants_allowed": false,
    "record_in": [
      "static_cache",
      "run_manifest.json",
      "training_config.json",
      "training_manifest.json"
    ]
  },
  "q_max_method": {
    "name": "lane_capacity_floor",
    "formula": "q_max_lane = max(1, floor(lane_length_m / avg_vehicle_length_m))",
    "avg_vehicle_length_m": 7.5
  },
  "phase_timer_normalization_method": {
    "name": "tls_program_green_duration_cap",
    "formula": "phase_timer_norm = min(phase_elapsed_s / phase_timer_max_s, 1.0)",
    "phase_timer_max_s_source": "derived from TLS program metadata (selectable green-phase duration cap)"
  },
  "lookahead_distance_method": {
    "name": "speed_times_decision_interval",
    "formula": "lookahead_distance_m_lane = lane_max_speed_mps * decision_interval_s",
    "lane_speed_source": "SUMO lane metadata at startup cache build"
  },
  "observation_contract": {
    "field_order": [
      "phase_one_hot",
      "phase_timer_normalized",
      "incoming_queue_normalized_per_lane",
      "incoming_running_lookahead_normalized_per_lane",
      "outgoing_queue_normalized_per_lane"
    ],
    "neighbor_observations_allowed": false,
    "graph_message_passing_allowed": false,
    "shared_weights_allowed": false,
    "transfer_across_networks_allowed": false
  },
  "action_space_definition": {
    "action": "target selectable green phase index for that TLS",
    "action_mask": {
      "key": "action_mask",
      "shape": "(num_selectable_green_phases,)",
      "dtype": "bool",
      "true_meaning": "valid action",
      "false_meaning": "invalid action"
    },
    "agent_selects_yellow_or_all_red_directly": false
  },
  "yellow_all_red_handling": {
    "handled_by": "environment/SUMO transition logic",
    "agent_direct_control": false
  },
  "train_every_steps": 8,
  "learning_starts_steps": 1000,
  "training_metrics_contract": {
    "purpose": "lightweight per-episode diagnostics/proxies during training",
    "heavy_benchmark_xml_default": false,
    "metrics": [
      "episode_reward_sum",
      "episode_loss_mean",
      "episode_loss_update_count",
      "episode_wall_time_s",
      "episode_steps",
      "episode_arrived_vehicles",
      "episode_throughput_proxy",
      "episode_mean_queue_count_or_length_proxy",
      "episode_phase_change_count",
      "episode_phase_change_rate",
      "episode_waiting_proxy_if_available_without_per_vehicle_calls"
    ],
    "note": "Training curves are diagnostic proxies and are not asserted equal to final benchmark KPIs unless computed by the same extraction pipeline."
  },
  "final_evaluation_kpi_contract": {
    "source": "full frozen scenario outputs + exact extraction pipeline",
    "kpis": [
      "mean_waiting_time_completed_s",
      "throughput_completed_trips",
      "mean_total_queue_length_m",
      "phase_change_rate_per_tls_per_min"
    ]
  },
  "reward_contract": {
    "name": "aggregate_local_efficient_pressure_v2",
    "formula": "reward_i = -(sum(incoming_queue_norm + incoming_running_lookahead_norm) - sum(outgoing_queue_norm))",
    "known_limitation": "If outgoing lanes are congested, pressure reward can move toward zero even under heavy load. This is a known property of pressure-style rewards, not a parser bug."
  },
